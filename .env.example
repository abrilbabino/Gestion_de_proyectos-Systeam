# Base de datos
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/systeam
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Puerto del servidor
SERVER_PORT=8081

# SMTP Mail (opcional — defaults apuntan a Mailpit en localhost:1025 sin auth)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
