                "",
                "pm.test('Status 201 Creado', () => pm.response.to.have.status(201));",
                "",
                "pm.test('Inversión creada correctamente', function () {",
                "    ['id','usuarioId','proyectoId','proyectoTitulo','montoIdea','subTokensRecibidos','txHash','estado'].forEach(c => {",
